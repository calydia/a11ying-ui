{
  "name": "a11ying-ui",
  "version": "2.0.8",
  "description": "Shared design system for A11ying brand sites",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": "./dist/tailwind.config.cjs",
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/global.css"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build --config vite.config.build.ts && tsc --emitDeclarationOnly",
    "prepare": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:unit": "vitest run src/**/*.test.ts",
    "test:storybook": "playwright test --config playwright.storybook.config.ts",
    "test:storybook:update": "playwright test --config playwright.storybook.config.ts --update-snapshots"
  },
  "keywords": [],
  "author": "Sanna Kramsi",
  "license": "MIT",
  "dependencies": {
    "qs-esm": "^8.0.1",
    "sanitize-html": "^2.17.5"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@chromatic-com/storybook": "^5.1.2",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/satisfy": "^5.2.7",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
