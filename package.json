{
  "name": "a11ying-ui",
  "version": "1.6.0",
  "description": "Shared design system for A11ying brand sites",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": "./dist/tailwind.config.cjs",
    "./styles": "./dist/global.css"
  },
  "scripts": {
    "build": "vite build --config vite.config.build.ts",
    "prepare": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "playwright test --config playwright.storybook.config.ts",
    "test:storybook:update": "playwright test --config playwright.storybook.config.ts --update-snapshots"
  },
  "keywords": [],
  "author": "Sanna Kramsi",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^5.0.1",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/satisfy": "^5.2.7",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "playwright": "^1.58.2",
    "prop-types": "^15.8.1",
    "qs-esm": "^7.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.19",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.0"
  }
}
